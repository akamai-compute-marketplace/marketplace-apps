upstream nomad {
    server 127.0.0.1:{{ nomad_http_port }};
}

server {
    listen 80;
    server_name {{ _domain }};

    location / {
        auth_basic "Nomad";
        auth_basic_user_file {{ nomad_htpasswd_file }};

        proxy_pass http://nomad;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # Nomad blocking queries can stay open up to 5 minutes
        proxy_read_timeout 340s;
        # Log/event streaming needs buffering off
        proxy_buffering off;
    }
}
