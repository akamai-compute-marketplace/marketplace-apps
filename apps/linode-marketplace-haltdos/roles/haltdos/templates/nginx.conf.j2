# HaltDOS Community WAF — management UI fronted by nginx
#
# Layout:
#   - port 80:  reserved for the offloader (WAF data plane) once the user
#               configures their first listener via the management GUI.
#               nginx does not bind 80; we leave it unconfigured here so
#               that certbot's HTTP-01 renewal challenges can use it before
#               the offloader takes it over.
#   - port 443: same as 80 — reserved for the offloader.
#   - port 9000 (haltdos_ext_port): SSL terminating reverse proxy →
#               https://127.0.0.1:9001 (the controller's loopback bind).
#
# nginx auth scope (Path A): basic auth gates only the setup wizard
# endpoints. Login + native UI rely on the controller's own auth.

server {
    listen {{ haltdos_ext_port }} ssl http2;
    listen [::]:{{ haltdos_ext_port }} ssl http2;
    server_name {{ _domain }};

    # certbot --nginx will inject ssl_certificate / ssl_certificate_key

    # The controller listens HTTPS on 127.0.0.1:9001 with a self-signed
    # cert baked into the WAR. Skip cert verification for the loopback
    # hop only — the user-facing TLS is the LE cert nginx terminates.

    # Wizard endpoints — gated by nginx basic auth (Path A scope).
    location ~ ^/(setup|api/register|api/setup)(/|$) {
        auth_basic           "HaltDOS Setup";
        auth_basic_user_file {{ haltdos_htpasswd_file }};

        proxy_pass            https://{{ haltdos_bind_addr }}:{{ haltdos_internal_port }};
        proxy_ssl_verify      off;
        proxy_set_header      Host              $host;
        proxy_set_header      X-Real-IP         $remote_addr;
        proxy_set_header      X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto https;
        proxy_set_header      X-Forwarded-Port  {{ haltdos_ext_port }};
        proxy_set_header      X-Forwarded-Host  $host;

        proxy_read_timeout    120s;
        proxy_send_timeout    120s;
    }

    # All other paths — controller's native auth is sole gate.
    location / {
        proxy_pass            https://{{ haltdos_bind_addr }}:{{ haltdos_internal_port }};
        proxy_ssl_verify      off;
        proxy_set_header      Host              $host;
        proxy_set_header      X-Real-IP         $remote_addr;
        proxy_set_header      X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto https;
        proxy_set_header      X-Forwarded-Port  {{ haltdos_ext_port }};
        proxy_set_header      X-Forwarded-Host  $host;

        proxy_read_timeout    120s;
        proxy_send_timeout    120s;
    }
}
