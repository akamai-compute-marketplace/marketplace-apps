# rtSurvey Credentials
# Generated on {{ ansible_date_time.date }}
# Keep this file secure — chmod 600

App URL:              http://{{ server_ip }}
                      (HTTPS will activate after you set a domain via the app UI)

Admin Login:
  Username:           admin
  Password:           {{ admin_password }}

Database:
  Name:               {{ rtsurvey_project_id }}
  User:               {{ rtsurvey_project_id }}
  Password:           {{ mysql_password }}
  Root Password:      {{ mysql_root_password }}

{% if embed_keycloak %}
Keycloak (SSO):
  URL:                http://{{ server_ip }}/auth/admin
  Admin User:         admin
  Admin Password:     {{ keycloak_admin_password }}
{% endif %}

Logs:
  StackScript:        /var/log/stackscript.log
  SSL trigger:        /var/log/rtsurvey-ssl.log
  App files:          {{ rtsurvey_deploy_dir }}/
