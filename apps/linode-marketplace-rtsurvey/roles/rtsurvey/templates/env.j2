# Generated by Linode StackScript on {{ ansible_date_time.date }}

# Project
PROJECT_ID={{ rtsurvey_project_id }}
PROJECT_TYPE=rtsurvey
PROJECT_URL={{ server_ip }}
SERVER_IP={{ server_ip }}
PROJECT_PORT=80
HTTP_PROTOCOL=http

# Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE={{ rtsurvey_project_id }}
MYSQL_USER={{ rtsurvey_project_id }}
MYSQL_PASSWORD={{ mysql_password }}
MYSQL_ROOT_PASSWORD={{ mysql_root_password }}

# Admin
ADMIN_PASSWORD={{ admin_password }}

# Ports
APP_PORT={{ app_port }}
SHINY_PORT={{ shiny_port }}
KEYCLOAK_PORT={{ keycloak_port }}

# Runtime
RUN_ENV=prod
RUN_MODE=admin
TZ={{ tz | default('Asia/Ho_Chi_Minh') }}
LOG_LEVEL=info

# Security
CSRF_VALIDATION_ENABLED=true
GII_ENABLED=false

# Docker
COMPOSE_PROJECT_NAME={{ rtsurvey_project_id }}
RESTART_POLICY={{ restart_policy }}
RTSURVEY_IMAGE={{ rtsurvey_image }}
DEPLOYMENT_MODEL=docker

# SSO mode
EMBED_KEYCLOAK={{ embed_keycloak | lower }}

# Stata
STATA_ENABLED={{ stata_enabled | lower }}
LETSENCRYPT_EMAIL=info@rta.vn
STATA_BIN_PATH=/usr/bin/stata
STATA_LICENSE_B64={{ stata_license_b64 }}

{% if embed_keycloak %}
AUTH_PROVIDER=embedded-keycloak

# SSO - Embedded Keycloak
OIDC_ISSUER_URL=http://{{ server_ip }}/auth/realms/rtsurvey
OIDC_CLIENT_ID={{ rtsurvey_project_id }}
OIDC_CLIENT_SECRET={{ oidc_client_secret }}
OIDC_REDIRECT_URI=http://{{ server_ip }}/cpms/cpmsSite/auth
OIDC_DISCOVERY_URL=http://keycloak:8080/auth/realms/rtsurvey/.well-known/openid-configuration
OIDC_MOBILE_CLIENT_ID={{ rtsurvey_project_id }}
OIDC_MOBILE_REDIRECT_URI=vn.rta.rtsurvey.auth://callback

KC_HOSTNAME=http://{{ server_ip }}/auth
KC_HEALTH_ENABLED=true
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD={{ keycloak_admin_password }}
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD={{ keycloak_db_password }}
{% endif %}
